<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
  <CodeCoverage>
    <ModulePaths>
      <Exclude>
        <ModulePath>.*HashTableRx\.Reactive\.dll$</ModulePath>
      </Exclude>
    </ModulePaths>
    <Sources>
      <Exclude>
        <Source>.*[\\/]obj[\\/].*</Source>
      </Exclude>
    </Sources>
  </CodeCoverage>
</Configuration>
